# ── Banco de dados (Supabase Postgres) ──────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ── Auth ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET="troque-por-um-valor-aleatorio-de-64+-chars"
JWT_REFRESH_SECRET="outro-valor-aleatorio-diferente-do-acima"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── CORS — domínios explicitamente autorizados ─────────────
CORS_ALLOWED_ORIGINS="https://linea-pdr.com,https://www.linea-pdr.com"

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="200"

# ── Pagamentos (Stripe) ─────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Migração one-off Supabase -> Prisma (scripts/migrate-from-supabase.ts) ──
# Só necessárias pra rodar o script uma vez; pode remover depois.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
